<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base application theme — Material Design 3
        Applied to all activities unless overridden.
    -->
    <style name="Theme.ServiceCallApp" parent="Theme.Material3.Light.NoActionBar">

        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>

        <!-- Surface / Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOutline">@color/outline</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>

        <!-- Status bar — transparent, dark icons -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/surface</item>

        <!-- Shape system — rounded corners -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>

        <!-- Typography -->
        <item name="textAppearanceBodyLarge">@style/TextAppearance.ServiceCallApp.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.ServiceCallApp.BodyMedium</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.ServiceCallApp.TitleLarge</item>

    </style>

    <!-- Splash screen theme — shown during cold start -->
    <style name="Theme.ServiceCallApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenBrandingImage">@drawable/ic_splash_brand</item>
        <item name="postSplashScreenTheme">@style/Theme.ServiceCallApp</item>
    </style>

    <!-- ── Shape Styles ─────────────────────────────────────── -->
    <style name="ShapeSmall" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeMedium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeLarge" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- ── Typography ───────────────────────────────────────── -->
    <style name="TextAppearance.ServiceCallApp.TitleLarge"
        parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ServiceCallApp.BodyLarge"
        parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ServiceCallApp.BodyMedium"
        parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ── Button Style ─────────────────────────────────────── -->
    <style name="Widget.ServiceCallApp.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- ── TextInputLayout Style ────────────────────────────── -->
    <style name="Widget.ServiceCallApp.TextInputLayout"
        parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- ── Card Style ───────────────────────────────────────── -->
    <style name="Widget.ServiceCallApp.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <!-- ── Toolbar style ────────────────────────────────────── -->
    <style name="Widget.ServiceCallApp.Toolbar" parent="Widget.Material3.Toolbar.Surface">
        <item name="android:background">@color/surface</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

</resources>
