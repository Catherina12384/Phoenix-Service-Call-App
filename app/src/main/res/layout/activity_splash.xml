<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_splash.xml
    Simple background layout — the actual branding is handled by
    the SplashScreen API (windowSplashScreenAnimatedIcon in themes.xml).
    This layout is only briefly visible as the post-splash content
    while Firestore auth check completes.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Container for centering all content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- App Logo -->
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/ic_logo"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:contentDescription="@string/company_logo" />

        <!-- App name shown below the icon -->
        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/company_name"
            android:textColor="@color/primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tv_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/app_tagline"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:gravity="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
