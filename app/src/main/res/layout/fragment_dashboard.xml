<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_dashboard.xml

    ┌──────────────────────────────────┐
    │  Today's Summary                 │
    │  [Pending] [Done] [Overdue]      │  summary cards row
    │  [Snoozed]                       │
    │  ─────────────────────────────   │
    │  [Filter bar — date/status/etc]  │
    │  ─────────────────────────────   │
    │  Team Overview (owner only)      │
    │  [Agent card] [Agent card] ...   │
    └──────────────────────────────────┘
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="80dp">

        <!-- ── Section: Today's Summary ─────────────────────── -->
        <TextView
            android:id="@+id/tv_section_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Summary"
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"/>

        <!-- Summary cards: 2 columns -->
        <GridLayout
            android:id="@+id/grid_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="false">

            <!-- Pending -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_pending"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/status_pending_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textSize="12sp"
                        android:textColor="@color/status_pending"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_pending_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_pending"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Done -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_done"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/status_done_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completed"
                        android:textSize="12sp"
                        android:textColor="@color/status_done"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_done_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_done"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Overdue -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_overdue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/status_overdue_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overdue"
                        android:textSize="12sp"
                        android:textColor="@color/status_overdue"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_overdue_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_overdue"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Snoozed -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_snoozed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/status_snoozed_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Snoozed"
                        android:textSize="12sp"
                        android:textColor="@color/status_snoozed"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_snoozed_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_snoozed"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- ── Filter Bar ─────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter Tasks"
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Date range row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_date_from"
                        style="@style/Widget.ServiceCallApp.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="From Date">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_date_from"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:focusable="false"
                            android:textSize="14sp"
                            android:paddingVertical="12dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <View android:layout_width="8dp" android:layout_height="1dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_date_to"
                        style="@style/Widget.ServiceCallApp.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="To Date">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_date_to"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:focusable="false"
                            android:textSize="14sp"
                            android:paddingVertical="12dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- Status dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_filter_status"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/status_label"
                    android:focusable="true"
                    android:importantForAccessibility="yes"
                    android:contentDescription="@string/status_label"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/dropdown_filter_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textSize="14sp"
                        android:paddingVertical="12dp"
                        android:focusable="false"
                        android:importantForAccessibility="no"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Service type dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_filter_service"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/service_type"
                    android:focusable="true"
                    android:importantForAccessibility="yes"
                    android:contentDescription="@string/service_type"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/dropdown_filter_service"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textSize="14sp"
                        android:paddingVertical="12dp"
                        android:focusable="false"
                        android:importantForAccessibility="no"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Customer name search -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_filter_customer"
                    style="@style/Widget.ServiceCallApp.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Customer Name"
                    android:layout_marginTop="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_filter_customer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textSize="14sp"
                        android:paddingVertical="12dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Created by dropdown (owner only — hidden for agents) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_filter_agent"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/created_by"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">
                    <AutoCompleteTextView
                        android:id="@+id/dropdown_filter_agent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textSize="14sp"
                        android:paddingVertical="12dp"
                        android:hint="@string/created_by"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Filter action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_apply_filter"
                        style="@style/Widget.ServiceCallApp.Button"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:text="Apply Filter"
                        android:textSize="14sp"/>

                    <View android:layout_width="10dp" android:layout_height="1dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_filter"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:text="Clear"
                        app:cornerRadius="12dp"
                        android:textSize="14sp"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Team Overview — owner only ────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_team_overview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Team Overview"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"/>

            <!-- Agent cards injected here programmatically -->
            <LinearLayout
                android:id="@+id/container_agents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"/>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>