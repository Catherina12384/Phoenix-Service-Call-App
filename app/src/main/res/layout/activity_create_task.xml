<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_create_task.xml
    Full-screen form for manually creating a new task.

    Layout:
    ┌─────────────────────────────────┐
    │  ← New Task          [SAVE]     │  Toolbar
    ├─────────────────────────────────┤
    │  Customer Name *                │
    │  Customer Phone *               │
    │  Service Type * [dropdown]      │
    │  Description (optional)         │
    │  ─────────────────────────────  │
    │  Call Type:  [Office] [Personal]│
    └─────────────────────────────────┘
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            style="@style/Widget.ServiceCallApp.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="New Task" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="40dp">

            <!-- ── Section: Customer Details ──────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/customer_details"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <!-- Customer Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_customer_name"
                style="@style/Widget.ServiceCallApp.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/customer_name"
                app:startIconDrawable="@drawable/ic_profile"
                app:startIconTint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_customer_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName|textCapWords"
                    android:imeOptions="actionNext"
                    android:textSize="16sp"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Customer Phone -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_customer_phone"
                style="@style/Widget.ServiceCallApp.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/customer_phone"
                android:layout_marginTop="12dp"
                app:startIconDrawable="@drawable/ic_calls"
                app:startIconTint="@color/text_secondary"
                app:endIconMode="clear_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_customer_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:imeOptions="actionNext"
                    android:maxLength="15"
                    android:textSize="16sp"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Section: Service Details ───────────────── -->
            <TextView
                android:id="@+id/label_service_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/service_details"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:labelFor="@id/dropdown_service_type" />

            <!-- Service Type Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_service_type"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/service_type"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:startIconDrawable="@drawable/ic_tasks"
                app:startIconTint="@color/text_secondary">

                <AutoCompleteTextView
                    android:id="@+id/dropdown_service_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textSize="16sp"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Description -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_description"
                style="@style/Widget.ServiceCallApp.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/description"
                android:layout_marginTop="12dp"
                app:counterEnabled="true"
                app:counterMaxLength="500">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="3"
                    android:maxLines="5"
                    android:maxLength="500"
                    android:gravity="top"
                    android:textSize="15sp"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Section: Call Type ──────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/call_type"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp" />

            <!-- Toggle group: Office / Personal -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_call_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_office"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="@string/call_type_office"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_personal"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="@string/call_type_personal"
                    app:cornerRadius="12dp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Personal call notice (shown when Personal selected) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_personal_notice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/status_snoozed_bg"
                app:cardElevation="0dp"
                app:strokeColor="@color/status_snoozed"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="@string/personal_call_notice"
                    android:textSize="13sp"
                    android:textColor="@color/status_snoozed" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_task"
                style="@style/Widget.ServiceCallApp.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:text="@string/save_task" />

            <!-- Progress indicator -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:indicatorColor="@color/primary"
                app:trackColor="@color/primary_container" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>