<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_contacts.xml
    Office contacts list — owner can add/edit/delete, agents can view and add.

    ┌──────────────────────────────────┐
    │  ← Office Contacts    [+Add]     │
    ├──────────────────────────────────┤
    │  🔍 Search contacts...           │
    │  ─────────────────────────────   │
    │  Contact card (name + phone)     │
    │  Contact card ...                │
    └──────────────────────────────────┘
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            style="@style/Widget.ServiceCallApp.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Office Contacts">

            <!-- Add contact button -->
            <ImageButton
                android:id="@+id/action_add_contact"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add"
                app:tint="@color/primary"
                android:contentDescription="Add Contact"/>

        </androidx.appcompat.widget.Toolbar>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Loading bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:indicatorColor="@color/primary"
        app:trackColor="@color/primary_container"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Search bar -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_search"
            style="@style/Widget.ServiceCallApp.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="12dp"
            android:hint="Search by name or phone"
            app:startIconDrawable="@drawable/ic_calls"
            app:startIconTint="@color/text_secondary"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textSize="15sp"
                android:paddingVertical="12dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Contact list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_contacts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="24dp"
            android:clipToPadding="false"
            android:scrollbars="none"/>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/outline"
                android:alpha="0.5"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No office contacts yet"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap + to add your first contact"
                android:textSize="14sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>